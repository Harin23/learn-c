# learn-c Phase 8 base config fragment
# Merge into kernel .config after defconfig:
#   ./scripts/kconfig/merge_config.sh .config /path/to/learn-c-base.config
#   make olddefconfig

CONFIG_LOCALVERSION="-learn-c"
CONFIG_DEBUG_KERNEL=y
CONFIG_PRINTK=y
CONFIG_DEBUG_INFO=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_SCHED_TRACER=y
CONFIG_TRACING=y
CONFIG_DEBUG_FS=y
CONFIG_BLK_DEV_INITRD=y
